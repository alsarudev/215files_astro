---
import logo from "../assets/logo-imagen.png";

const menuItems = [
    {
        text: "PROYECTOS",
        href: "#proyectos"
    },
    {
        text: "CONTACTO",
        href: "#contacto"
    }
];
---

<header class="fixed top-0 left-0 w-full z-50 transition-all duration-300 pt-6" id="main-header">
    <nav class="container mx-auto px-8 md:px-16 lg:px-24">
        <div class="flex justify-between items-center md:justify-between justify-center">
            <div class="w-72 md:w-48 lg:w-72 flex items-center mt-2">
                <img 
                    src={logo.src}
                    alt="Logo de 215 Files"
                    class="w-full h-auto"
                />
            </div>
            <div class="hidden md:flex space-x-16 items-center mt-2">
                {menuItems.map((item) => (
                    <a 
                        href={item.href} 
                        class="text-white hover:text-[rgb(255,43,57)] font-medium transition-all duration-300 hover:scale-110 text-xl md:text-xl lg:text-3xl"
                    >
                        {item.text}
                    </a>
                ))}
            </div>
        </div>
    </nav>
</header>