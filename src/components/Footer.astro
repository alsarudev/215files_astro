---
// Generamos el año dinámicamente en el servidor en cada compilación
const currentYear = new Date().getFullYear();
---
<footer class="bg-black text-white w-full py-16 border-t border-white/10 relative overflow-hidden">
  <!-- Sombra ligera tipo blur en la cima del footer -->
  <div class="absolute top-0 left-1/2 -translate-x-1/2 w-full h-[1px] bg-gradient-to-r from-transparent via-white/10 to-transparent"></div>
  
  <div class="container mx-auto flex flex-col md:flex-row justify-between items-center md:items-start px-4">
    <div class="mb-8 md:mb-0 text-center md:text-left">
      <h3 class="text-xl md:text-2xl font-semibold mb-4 tracking-wide text-zinc-300">Contacto</h3>
      <p class="mb-2 text-zinc-400">Email: <a href="mailto:215filesprods@gmail.com" class="text-white underline decoration-white/30 underline-offset-4 hover:text-[rgb(255,43,57)] hover:decoration-[rgb(255,43,57)] transition-all">215filesprods@gmail.com</a></p>
      <p class="text-sm text-zinc-500">Dirección: Alcorcón, Madrid</p>
    </div>
    <div class="mb-8 md:mb-0 text-center order-last md:order-none w-full md:w-auto mt-10 md:mt-0 pt-8 md:pt-0 border-t border-white/10 md:border-none">
      <p class="mt-0 md:mt-12 text-sm text-zinc-500 font-medium tracking-wide">© {currentYear} 215FILES. Todos los derechos reservados.</p>
    </div>
    <div class="text-center md:text-right">
      <h3 class="text-xl md:text-2xl font-semibold mb-4 tracking-wide text-zinc-300">Síguenos</h3>
      <a href="https://instagram.com/215.files" target="_blank" rel="noopener noreferrer" class="inline-flex items-center justify-center p-3 mt-2 group rounded-full bg-white/5 hover:bg-[rgb(255,43,57)]/10 border border-white/10 hover:border-[rgb(255,43,57)]/50 transition-all duration-300 hover:scale-110 hover:shadow-[0_0_20px_rgba(255,43,57,0.3)]">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 448 512" fill="none" class="w-6 h-6 md:w-8 md:h-8 stroke-white group-hover:stroke-[rgb(255,43,57)] transition-colors duration-300">
          <rect x="48" y="80" width="352" height="352" rx="80" stroke-width="32" fill="none"/>
          <circle cx="224" cy="256" r="80" stroke-width="32" fill="none"/>
          <circle cx="352" cy="160" r="16" fill="currentColor" class="fill-white group-hover:fill-[rgb(255,43,57)] transition-colors duration-300"/>
        </svg>
      </a>
    </div>
  </div>
</footer> 