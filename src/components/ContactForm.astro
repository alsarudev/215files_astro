<section class="w-full py-20 px-4 md:px-8 relative bg-black scroll-mt-24" id="contacto">
    <div class="flex items-center mb-8 w-full px-4">
        <div class="hidden md:block flex-grow border-t border-white border-2" style="margin-right:1rem;"></div>
        <h2 class="text-center text-white text-4xl font-extrabold tracking-wider whitespace-nowrap">CONTACTO</h2>
        <div class="hidden md:block flex-grow border-t border-white border-2" style="margin-left:1rem;"></div>
    </div>
    <div class="container mx-auto max-w-4xl">
        <form id="contactForm" class="space-y-6">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <div>
                    <label for="name" class="block text-white mb-2">Nombre</label>
                    <input 
                        type="text" 
                        id="name" 
                        name="name" 
                        class="w-full px-4 py-3 bg-transparent border-2 border-white text-white rounded-lg focus:outline-none focus:border-[rgb(255,43,57)] transition-colors"
                        required
                    />
                </div>
                <div>
                    <label for="email" class="block text-white mb-2">Email</label>
                    <input 
                        type="email" 
                        id="email" 
                        name="email" 
                        class="w-full px-4 py-3 bg-transparent border-2 border-white text-white rounded-lg focus:outline-none focus:border-[rgb(255,43,57)] transition-colors"
                        required
                    />
                </div>
            </div>
            
            <div>
                <label for="message" class="block text-white mb-2">Mensaje</label>
                <textarea 
                    id="message" 
                    name="message" 
                    rows="6" 
                    class="w-full px-4 py-3 bg-transparent border-2 border-white text-white rounded-lg focus:outline-none focus:border-[rgb(255,43,57)] transition-colors resize-none"
                    required
                ></textarea>
            </div>
            
            <div class="text-center">
                <button 
                    type="submit" 
                    id="submitBtn"
                    class="px-8 py-3 bg-[rgb(255,43,57)] text-white rounded-lg hover:bg-opacity-90 transition-colors font-medium text-lg"
                >
                    Enviar Mensaje
                </button>
            </div>
        </form>

        <!-- Modal de éxito -->
        <div id="successModal" class="fixed inset-0 bg-black bg-opacity-50 flex items-center justify-center z-50 hidden">
            <div class="bg-white rounded-lg p-8 max-w-md w-full mx-4 transform transition-all">
                <div class="text-center">
                    <div class="mx-auto flex items-center justify-center h-12 w-12 rounded-full bg-green-100 mb-4">
                        <svg class="h-6 w-6 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                        </svg>
                    </div>
                    <h3 class="text-lg font-medium text-gray-900 mb-2">¡Mensaje enviado!</h3>
                    <p class="text-sm text-gray-500 mb-6">Tu mensaje ha sido enviado correctamente. Te responderemos pronto.</p>
                    <button 
                        id="closeSuccessModal"
                        class="w-full bg-[rgb(255,43,57)] text-white px-4 py-2 rounded-lg hover:bg-opacity-90 transition-colors font-medium"
                    >
                        Cerrar
                    </button>
                </div>
            </div>
        </div>

        <!-- Modal de error -->
        <div id="errorModal" class="fixed inset-0 bg-black bg-opacity-50 flex items-center justify-center z-50 hidden">
            <div class="bg-white rounded-lg p-8 max-w-md w-full mx-4 transform transition-all">
                <div class="text-center">
                    <div class="mx-auto flex items-center justify-center h-12 w-12 rounded-full bg-red-100 mb-4">
                        <svg class="h-6 w-6 text-red-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
                        </svg>
                    </div>
                    <h3 class="text-lg font-medium text-gray-900 mb-2">Error al enviar</h3>
                    <p id="errorMessage" class="text-sm text-gray-500 mb-6">Hubo un problema al enviar tu mensaje. Inténtalo de nuevo.</p>
                    <button 
                        id="closeErrorModal"
                        class="w-full bg-[rgb(255,43,57)] text-white px-4 py-2 rounded-lg hover:bg-opacity-90 transition-colors font-medium"
                    >
                        Cerrar
                    </button>
                </div>
            </div>
        </div>

        <script>
            const form = document.getElementById('contactForm') as HTMLFormElement;
            const submitBtn = document.getElementById('submitBtn') as HTMLButtonElement;
            const successModal = document.getElementById('successModal') as HTMLElement;
            const errorModal = document.getElementById('errorModal') as HTMLElement;
            const errorMessage = document.getElementById('errorMessage') as HTMLElement;
            const closeSuccessModal = document.getElementById('closeSuccessModal') as HTMLButtonElement;
            const closeErrorModal = document.getElementById('closeErrorModal') as HTMLButtonElement;
            
            // Función para mostrar modal de éxito
            function showSuccessModal() {
                successModal.classList.remove('hidden');
                successModal.classList.add('flex');
            }
            
            // Función para mostrar modal de error
            function showErrorModal(message: string) {
                errorMessage.textContent = message;
                errorModal.classList.remove('hidden');
                errorModal.classList.add('flex');
            }
            
            // Función para cerrar modales
            function closeModals() {
                successModal.classList.add('hidden');
                successModal.classList.remove('flex');
                errorModal.classList.add('hidden');
                errorModal.classList.remove('flex');
            }
            
            if (form && submitBtn) {
                form.addEventListener('submit', async (e) => {
                    e.preventDefault();
                    
                    const originalText = submitBtn.textContent;
                    submitBtn.textContent = 'Enviando...';
                    submitBtn.disabled = true;
                    
                    // Crear URLSearchParams en lugar de FormData
                    const formData = new FormData(form);
                    const params = new URLSearchParams();
                    params.append('name', formData.get('name') as string);
                    params.append('email', formData.get('email') as string);
                    params.append('message', formData.get('message') as string);
                    
                    try {
                        const response = await fetch('/api/contact', {
                            method: 'POST',
                            headers: {
                                'Content-Type': 'application/x-www-form-urlencoded',
                            },
                            body: params
                        });
                        
                        const result = await response.json();
                        
                        if (result.success) {
                            showSuccessModal();
                            form.reset();
                        } else {
                            showErrorModal(result.message || 'Error al enviar el mensaje');
                        }
                    } catch (error) {
                        showErrorModal('Error de conexión. Verifica tu internet.');
                        console.error('Error:', error);
                    } finally {
                        submitBtn.textContent = originalText;
                        submitBtn.disabled = false;
                    }
                });
            }
            
            // Event listeners para cerrar modales
            if (closeSuccessModal) {
                closeSuccessModal.addEventListener('click', closeModals);
            }
            
            if (closeErrorModal) {
                closeErrorModal.addEventListener('click', closeModals);
            }
            
            // Cerrar modal al hacer clic fuera de él
            if (successModal) {
                successModal.addEventListener('click', (e) => {
                    if (e.target === successModal) {
                        closeModals();
                    }
                });
            }
            
            if (errorModal) {
                errorModal.addEventListener('click', (e) => {
                    if (e.target === errorModal) {
                        closeModals();
                    }
                });
            }
            
            // Cerrar modal con la tecla Escape
            document.addEventListener('keydown', (e) => {
                if (e.key === 'Escape') {
                    closeModals();
                }
            });
        </script>
    </div>
</section> 