---
// Configuración del formulario
const formConfig = {
  fields: [
    { id: 'name', type: 'text' as const, label: 'Nombre', required: true },
    { id: 'email', type: 'email' as const, label: 'Email', required: true },
    { id: 'message', type: 'textarea' as const, label: 'Mensaje', required: true, rows: 6 }
  ]
};
---
<script src="/js/contact-form.js" defer></script> 
<section class="w-full py-24 px-4 md:px-8 relative bg-black scroll-mt-24 overflow-hidden" id="contacto">
    <!-- Luz de ambiente de fondo -->
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[800px] h-[800px] bg-[rgb(255,43,57)]/10 blur-[150px] rounded-full pointer-events-none"></div>

    <!-- Título de la sección premium -->
    <div class="flex items-center justify-center mb-16 w-full px-4 relative z-10">
        <div class="hidden md:block flex-grow h-[1px] bg-gradient-to-r from-transparent to-white/30 max-w-sm mr-8 gsap-reveal-line" style="transform-origin: right;"></div>
        <h2 class="text-center text-white text-3xl md:text-5xl font-black tracking-[0.2em] whitespace-nowrap drop-shadow-lg gsap-fade-up">CONTACTO</h2>
        <div class="hidden md:block flex-grow h-[1px] bg-gradient-to-l from-transparent to-white/30 max-w-sm ml-8 gsap-reveal-line" style="transform-origin: left;"></div>
    </div>

    <div class="container mx-auto max-w-3xl relative z-10">
        <!-- Glassmorphism Card Wrapper -->
        <div class="bg-zinc-950/40 backdrop-blur-2xl border border-white/10 p-8 md:p-12 rounded-[2.5rem] shadow-[0_0_50px_rgba(0,0,0,0.5)] relative overflow-hidden gsap-fade-up">
            <!-- Destello tenue en el borde superior de la tarjeta -->
            <div class="absolute top-0 left-0 w-full h-[1px] bg-gradient-to-r from-transparent via-white/20 to-transparent"></div>
            
            <!-- Formulario de contacto -->
            <form id="contactForm" class="space-y-8 relative z-10">
                <!-- Campos del formulario -->
                <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                    <div>
                        <label for="name" class="block text-zinc-300 mb-2 ml-2 text-sm font-medium tracking-wide">Nombre</label>
                        <input 
                            type="text" 
                            id="name" 
                            name="name" 
                            class="w-full px-5 py-4 bg-white/5 border border-white/10 text-white rounded-2xl focus:outline-none focus:border-[rgb(255,43,57)] focus:bg-white/10 focus:ring-1 focus:ring-[rgb(255,43,57)] transition-all placeholder:text-zinc-600 shadow-inner"
                            placeholder="Tu nombre completo"
                            required
                        />
                    </div>
                    <div>
                        <label for="email" class="block text-zinc-300 mb-2 ml-2 text-sm font-medium tracking-wide">Email</label>
                        <input 
                            type="email" 
                            id="email" 
                            name="email" 
                            class="w-full px-5 py-4 bg-white/5 border border-white/10 text-white rounded-2xl focus:outline-none focus:border-[rgb(255,43,57)] focus:bg-white/10 focus:ring-1 focus:ring-[rgb(255,43,57)] transition-all placeholder:text-zinc-600 shadow-inner"
                            placeholder="tucorreo@ejemplo.com"
                            required
                        />
                    </div>
                </div>
                
                <!-- Campo de mensaje -->
                <div>
                    <label for="message" class="block text-zinc-300 mb-2 ml-2 text-sm font-medium tracking-wide">Mensaje</label>
                    <textarea 
                        id="message" 
                        name="message" 
                        rows="5" 
                        class="w-full px-5 py-4 bg-white/5 border border-white/10 text-white rounded-2xl focus:outline-none focus:border-[rgb(255,43,57)] focus:bg-white/10 focus:ring-1 focus:ring-[rgb(255,43,57)] transition-all resize-none placeholder:text-zinc-600 shadow-inner"
                        placeholder="Cuentanos sobre tu idea..."
                        required
                    ></textarea>
                </div>
            
            <!-- Botón de envío Premium Rediseñado -->
            <div class="text-center pt-8">
                <button 
                    type="submit" 
                    id="submitBtn"
                    class="relative inline-flex items-center justify-center px-12 py-5 font-bold text-white text-lg tracking-wide bg-[rgb(255,43,57)] rounded-full hover:bg-[rgb(255,70,80)] hover:scale-[1.03] transition-all duration-300 shadow-[0_10px_40px_-10px_rgba(255,43,57,0.8)] focus:outline-none focus:ring-4 focus:ring-[rgb(255,43,57)]/30 group w-full md:w-auto"
                >
                    <!-- Capa de iluminación interna superior -->
                    <span class="absolute inset-0 w-full h-full rounded-full border border-white/20"></span>
                    
                    <span class="relative z-10 flex items-center gap-3">
                        Enviar Mensaje
                        <svg class="w-6 h-6 group-hover:translate-x-1.5 transition-transform duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg>
                    </span>
                </button>
            </div>
            </form>
        </div>

        <!-- Modal de éxito Premium -->
        <div id="successModal" class="fixed inset-0 bg-black/80 backdrop-blur-sm flex items-center justify-center z-50 transition-opacity duration-300" style="display: none;">
            <div class="bg-zinc-900 border border-white/10 rounded-[2rem] p-8 md:p-12 max-w-sm w-full mx-4 transform transition-all shadow-2xl scale-95 hover:scale-100 duration-500">
                <div class="text-center">
                    <div class="mx-auto flex items-center justify-center h-20 w-20 rounded-full bg-green-500/20 mb-6 relative">
                        <div class="absolute inset-0 bg-green-500 blur-xl opacity-20 rounded-full"></div>
                        <svg class="h-10 w-10 text-green-400 relative z-10" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                        </svg>
                    </div>
                    <h3 class="text-2xl font-bold text-white mb-2">¡Enviado!</h3>
                    <p class="text-zinc-400 mb-8 tracking-wide">Tu mensaje ha despegado. Te responderemos a la brevedad.</p>
                    <button 
                        id="closeSuccessModal"
                        class="w-full bg-white text-black px-6 py-3 rounded-full hover:bg-zinc-200 transition-colors font-bold shadow-[0_0_20px_rgba(255,255,255,0.2)]"
                    >
                        Entendido
                    </button>
                </div>
            </div>
        </div>

        <!-- Modal de error Premium -->
        <div id="errorModal" class="fixed inset-0 bg-black/80 backdrop-blur-sm flex items-center justify-center z-50 transition-opacity duration-300" style="display: none;">
            <div class="bg-zinc-900 border border-[rgb(255,43,57)]/30 rounded-[2rem] p-8 md:p-12 max-w-sm w-full mx-4 transform transition-all shadow-2xl scale-95 hover:scale-100 duration-500">
                <div class="text-center">
                    <div class="mx-auto flex items-center justify-center h-20 w-20 rounded-full bg-red-500/20 mb-6 relative">
                        <div class="absolute inset-0 bg-red-500 blur-xl opacity-20 rounded-full"></div>
                        <svg class="h-10 w-10 text-red-500 relative z-10" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
                        </svg>
                    </div>
                    <h3 class="text-2xl font-bold text-white mb-2">Hubo un problema</h3>
                    <p id="errorMessage" class="text-zinc-400 mb-8 tracking-wide">Algo salió mal durante el envío. Inténtalo de nuevo.</p>
                    <button 
                        id="closeErrorModal"
                        class="w-full bg-[rgb(255,43,57)] text-white px-6 py-3 rounded-full hover:bg-[rgb(255,43,57)]/80 transition-colors font-bold shadow-[0_0_20px_rgba(255,43,57,0.3)]"
                    >
                        Cerrar
                    </button>
                </div>
            </div>
        </div>
    </div>
</section>

