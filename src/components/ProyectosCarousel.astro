<!-- Swiper.js CDN -->
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css" />
<script src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js" defer></script>

<section class="bg-black py-12 scroll-mt-24" id="proyectos">
  <div class="flex items-center mb-10 w-full px-4">
    <div class="hidden md:block flex-grow border-t border-white border-2" style="margin-right:1rem;"></div>
    <h2 class="text-center text-white text-4xl font-extrabold tracking-wider whitespace-nowrap">PROYECTOS</h2>
    <div class="hidden md:block flex-grow border-t border-white border-2" style="margin-left:1rem;"></div>
  </div>
  <div class="relative">
    <button id="arrow-left" class="flex items-center justify-center absolute left-2 top-1/2 -translate-y-1/2 z-20 w-10 h-10 bg-black/60 rounded-full hover:bg-white/80 transition-colors group">
      <svg class="w-6 h-6 text-white group-hover:-translate-x-2 transition-transform duration-300" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/></svg>
    </button>
    <button id="arrow-right" class="flex items-center justify-center absolute right-2 top-1/2 -translate-y-1/2 z-20 w-10 h-10 bg-black/60 rounded-full hover:bg-white/80 transition-colors group">
      <svg class="w-6 h-6 text-white group-hover:translate-x-2 transition-transform duration-300" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
    </button>
    <div class="swiper proyectos-swiper max-w-7xl mx-auto px-4">
      <div class="swiper-wrapper">
        {proyectos.map((proyecto) => (
          <div class="swiper-slide">
            <img src={proyecto.src} alt={proyecto.alt} class="rounded-2xl w-full h-80 object-cover" />
          </div>
        ))}
      </div>
    </div>
  </div>
  <script type="text/javascript">
    document.addEventListener('DOMContentLoaded', function () {
      const swiper = new Swiper('.proyectos-swiper', {
        slidesPerView: 1,
        spaceBetween: 30,
        breakpoints: {
          640: { slidesPerView: 2 },
          1024: { slidesPerView: 4 }
        },
        loop: true,
        grabCursor: true,
        centeredSlides: false,
        autoplay: { delay: 3500, disableOnInteraction: false },
      });
      // Flechas
      document.getElementById('arrow-left').addEventListener('click', () => swiper.slidePrev());
      document.getElementById('arrow-right').addEventListener('click', () => swiper.slideNext());
    });
  </script>
</section> 