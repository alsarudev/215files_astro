---
// No se requieren props por ahora
---

<!-- Swiper.js CDN -->
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css" />
<script src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js" defer></script>

<section id="proyectos" class="w-full py-20 px-4 md:px-8 relative bg-black">
  <div class="flex items-center mb-8 w-full px-4">
    <div class="hidden md:block flex-grow border-t border-white border-2" style="margin-right:1rem;"></div>
    <h2 class="text-center text-white text-4xl font-extrabold tracking-wider whitespace-nowrap">PROYECTOS</h2>
    <div class="hidden md:block flex-grow border-t border-white border-2" style="margin-left:1rem;"></div>
  </div>
  <div class="swiper proyectos-swiper max-w-7xl mx-auto px-4">
    <div class="swiper-wrapper">
      <div class="swiper-slide">
        <img src="https://images.unsplash.com/photo-1519125323398-675f0ddb6308" alt="Proyecto 1" class="rounded-2xl w-full h-80 object-cover" />
      </div>
      <div class="swiper-slide">
        <img src="https://images.unsplash.com/photo-1506744038136-46273834b3fb" alt="Proyecto 2" class="rounded-2xl w-full h-80 object-cover" />
      </div>
      <div class="swiper-slide">
        <img src="https://images.unsplash.com/photo-1465101046530-73398c7f28ca" alt="Proyecto 3" class="rounded-2xl w-full h-80 object-cover" />
      </div>
      <div class="swiper-slide">
        <img src="https://images.unsplash.com/photo-1470770841072-f978cf4d019e" alt="Proyecto 4" class="rounded-2xl w-full h-80 object-cover" />
      </div>
    </div>
  </div>
  <script type="text/javascript">
    document.addEventListener('DOMContentLoaded', function () {
      new Swiper('.proyectos-swiper', {
        slidesPerView: 1,
        spaceBetween: 30,
        breakpoints: {
          640: { slidesPerView: 2 },
          1024: { slidesPerView: 4 }
        },
        loop: true,
        grabCursor: true,
        centeredSlides: false,
        autoplay: { delay: 1500, disableOnInteraction: false },
      });
    });
  </script>
</section> 